# runtime
MYSQL_PASSWORD=your_password
DB_SLOW_THRESHOLD=200ms
DB_LOG_LEVEL=warn

# Docker image build (mainland China defaults; override for overseas)
GOPROXY=https://goproxy.cn,direct
GOSUMDB=sum.golang.google.cn
# GO_IMAGE=golang:1.25.7-alpine
# RUNTIME_IMAGE=alpine:3.22
# APK_MIRROR=mirrors.aliyun.com
# Optional image rewrite when Hub is blocked, e.g.:
# GO_IMAGE=docker.m.daocloud.io/library/golang:1.25.7-alpine
# RUNTIME_IMAGE=docker.m.daocloud.io/library/alpine:3.22

REDIS_PASSWORD=

# inventory reconcile
INVENTORY_RECONCILE_ENABLED=true
INVENTORY_RECONCILE_INTERVAL=5m
INVENTORY_RECONCILE_TIMEOUT=3s

# RabbitMQ and order timeout
RABBITMQ_URL=amqp://order_app:order_dev_password@127.0.0.1:5672/
RABBITMQ_USER=order_app
RABBITMQ_PASSWORD=order_dev_password
ORDER_TIMEOUT_DELAY=30m

# JWT
JWT_SECRET=replace_with_a_32_plus_chars_random_secret

# test
MYSQL_TEST_PASSWORD=your_password
MYSQL_TEST_DATABASE=go_order_management_system_test
RUN_RABBITMQ_TEST=0
